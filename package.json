{
  "name": "spigot",
  "version": "1.0.6",
  "description": "Premium multi-platform code editor inspired by VS Code using screaming architecture.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spigot/spigot.git"
  },
  "main": "dist-electron/main/index.js",
  "type": "commonjs",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.cjs",
    "dev": "node scripts/copy-monaco.cjs && vite",
    "build": "node scripts/copy-monaco.cjs && tsc && vite build && electron-builder --publish never",
    "build:electron": "vite build",
    "postinstall": "node scripts/postinstall.cjs",
    "rebuild:native": "electron-builder install-app-deps",
    "rebuild": "corepack pnpm run rebuild:native",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "security:audit": "corepack pnpm audit --prod",
    "security:signatures": "npm audit signatures",
    "release:win": "node scripts/copy-monaco.cjs && tsc && vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.378.0",
    "node-pty": "^1.1.0",
    "typescript-language-server": "^5.2.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.0.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.5.0"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "Spigot",
        "repo": "spigot",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "appId": "com.gentleman.spigot",
    "productName": "Spigot",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "dist",
      "package.json"
    ],
    "win": {
      "icon": "logoSpigot.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Spigot-Install.${ext}"
    },
    "nsis": {
      "installerIcon": "logoSpigot.ico",
      "uninstallerIcon": "logoSpigot.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Spigot-Install.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node"
    ]
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=11.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
